# Local live integration tests are opt-in.
VERTESIA_LIVE_TESTS=0

# Set this to a non-placeholder sk- secret key for local live tests.
VERTESIA_API_KEY=

# Vertesia developers can point tests at local or dev split services.
VERTESIA_STS_URL=http://localhost:8093
VERTESIA_STUDIO_URL=http://localhost:8091/api/v1
VERTESIA_ZENO_URL=http://localhost:8092/api/v1
