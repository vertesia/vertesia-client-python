# Copy this file to .env for local generated Go client integration tests.
# The live tests are skipped unless VERTESIA_LIVE_TESTS=1 is set.

VERTESIA_LIVE_TESTS=
VERTESIA_API_KEY=
VERTESIA_STS_URL=https://sts.vertesia.io
VERTESIA_STUDIO_URL=https://api.vertesia.io/api/v1
VERTESIA_ZENO_URL=https://api.vertesia.io/api/v1

# Optional: pin tests to a specific project instead of using the first account project.
VERTESIA_PROJECT_ID=
